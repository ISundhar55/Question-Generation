# ─── LLM Provider ────────────────────────────────────────────
# Switch between providers by changing LLM_PROVIDER
# Options: "gemini" | "groq"
LLM_PROVIDER=groq

# ─── Google Gemini ────────────────────────────────────────────
# Get key: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ─── Groq ─────────────────────────────────────────────────────
# Get key: https://console.groq.com  (free, no credit card)
# Limits: up to 6,000 req/day + 500K tokens/day on free plan
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Service ──────────────────────────────────────────────────
PORT=8000

# ─── Token Optimisation ───────────────────────────────────────
# RETRIEVAL_K   : Number of syllabus chunks retrieved per request.
#                 Lower = fewer tokens, less context. Default: 5.
#                 Recommended range: 3 (lean) – 7 (rich context).
RETRIEVAL_K=5

# MAX_CHUNK_CHARS : Maximum characters taken from a single chunk.
#                   Prevents very long paragraphs from dominating
#                   the context window. Default: 800.
#                   Increase if questions miss important context.
MAX_CHUNK_CHARS=800
